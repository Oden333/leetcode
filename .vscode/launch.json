{
  "version": "0.2.0",
  "configurations": [
    {
      "env": {
        "GOTESTS_TEMPLATE_DIR": "${workspaceFolder}/.vscode/gotests/templates"
      }
    },
    {
      "name": "Launch Current File",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${file}",
      // "buildFlags": "-tags=ignore",
      "console": "integratedTerminal",
      "args": []
      // "showLog": true
    },
    {
      "name": "Launch Package",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${fileDirname}",
      "console": "integratedTerminal",
      "args": []
    },
    {
      "name": "Launch with Arguments",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${file}",
      "console": "integratedTerminal",
      "args": ["arg1", "arg2"]
    },
    {
      "name": "Launch Test Current File",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${file}",
      "console": "integratedTerminal"
    }
  ]
}
